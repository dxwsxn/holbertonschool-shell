#!/usr/bin/env bash
# Displays numbers in 1 to 100 format. 
# displays fizzbuzz in multiples of 3 and 5
# displays fizz if mupltiple of 3
# displays buzz if multiple of 5
for i in {1..100};
do
	if [ "'expr $i % 15'" == "0"]
	then 
		print "FizzBuzz"
	elif [ "'expr $i % 3'" == "0"]
	then 
		print "Fizz"
	elif [ "'expr $i % 5'" == "0"]
	then
		print "Buzz"
	else
		echo "$i"
	fi

done
